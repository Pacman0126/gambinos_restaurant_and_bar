# =====================================================
# Database (Neon.tech PostgreSQL connection string)
# Get this from Neon console > Project > Connect button > Copy connection string
# =====================================================
DATABASE_URL=postgresql://[>format => neondb_owner:abc123def456ghi789jkl012mno345pqr@ep-cool-project-987654.us-east-2.aws.neon.tech/gambinos?sslmode=require <]

# =====================================================
# Django Secret Key (required - generate a secure one!)
# Command: python -c "import secrets; print(secrets.token_urlsafe(50))"
# =====================================================
SECRET_KEY=django-insecure-this-is-only-for-example-do-not-use-in-prod-abc123xyz789

# =====================================================
# Email Configuration (Brevo SMTP - transactional emails)
# SMTP credentials from Brevo > Settings > SMTP & API > SMTP tab
# =====================================================
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend   # Uncomment for local testing (prints to console)

EMAIL_HOST=smtp-relay.brevo.com
EMAIL_PORT=587
EMAIL_USE_TLS=True

# Your primary Brevo SMTP credentials (original domain)
EMAIL_HOST_USER=[Brevo smtp here]@smtp-brevo.com
EMAIL_HOST_PASSWORD=[>format => xsmtpsib-eAbCdEfGhIjKlMnOpQrStUvWxYz0123456789abcdef <]

DEFAULT_FROM_EMAIL="Gambino's Restaurant & Lounge <no-reply@gambinosrestaurantandlounge.com>"
SERVER_EMAIL=no-reply@gambinosrestaurantandlounge.com

# Alternative / fallback Brevo config (new domain) - comment/uncomment as needed
# EMAIL_HOST_USER=a3af8f001@smtp-brevo.com
# EMAIL_HOST_PASSWORD=[>format => xsmtpsib-9876543210ZYXWVUTSRQPONMLKJIHGFEDCBA <]
# DEFAULT_FROM_EMAIL="Gambino's Restaurant & Lounge <no-reply@gambinosrestaraunt.com>"
# SERVER_EMAIL=no-reply@gambinosrestaraunt.com

# =====================================================
# Optional / Development settings
# =====================================================
DEBUG=True
DJANGO_PRODUCTION=False

# Hosts & CSRF (comma-separated - add your real domain in production)
ALLOWED_HOSTS=127.0.0.1,localhost,0.0.0.0,.herokuapp.com,gambinosrestaurantandlounge.com

CSRF_TRUSTED_ORIGINS=http://127.0.0.1,http://127.0.0.1:8000,http://localhost,http://localhost:8000,https://gambinosrestaurantandlounge.herokuapp.com,https://gambinosrestaurantandlounge.com
